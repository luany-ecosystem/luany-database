parameters:
    level: 6
    paths:
        - src
    treatPhpDocTypesAsCertain: false
    ignoreErrors:
        # Active Record pattern requires new static() to return the correct subclass.
        # This is the standard ORM design — User::find() must return User, not Model.
        # All affected methods have correct @return static / @return array<int, static>.
        -
            identifier: new.static
            path: src/Model.php

        -
            identifier: new.static
            path: src/Connection.php

        -
            identifier: new.static
            path: src/QueryBuilder.php

        # Model uses protected static $connection and $eagerLoad via static::.
        # This is intentional Active Record inheritance — subclasses share the
        # connection without redeclaring it. private → protected already applied.
        -
            identifier: staticClassAccess.privateProperty
            path: src/Model.php

        -
            identifier: staticClassAccess.privateMethod
            path: src/Model.php

        # SoftDeletes trait is shipped for application use. PHPStan cannot see
        # the application's model classes that will declare: use SoftDeletes;
        -
            identifier: trait.unused
            path: src/Concerns/SoftDeletes.php

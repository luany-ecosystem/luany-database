{
    "name": "luany/database",
    "description": "Database layer for the Luany ecosystem — PDO connection, Model base, QueryBuilder, and Migration engine.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "António Ambrósio Ngola",
            "email": "antoniongola.dev@gmail.com",
            "homepage": "https://github.com/luany-ecosystem",
            "role": "Lead Engineer"
        }
    ],
    "keywords": [
        "php",
        "database",
        "orm",
        "activerecord",
        "query-builder",
        "migrations",
        "pdo",
        "luany"
    ],
    "homepage": "https://github.com/luany-ecosystem/luany-database",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "Luany\\Database\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Luany\\Database\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true
    },
    "minimum-stability": "stable"
}
